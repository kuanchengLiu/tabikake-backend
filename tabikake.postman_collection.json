				},
				{
					"name": "POST /trips",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var res = pm.response.json();",
									"if (res.trip && res.trip.id) {",
									"  pm.collectionVariables.set('tripId', res.trip.id);",
									"  console.log('Trip ID saved:', res.trip.id);",
									"}",
									"if (res.trip && res.trip.invite_code) {",
									"  pm.collectionVariables.set('inviteCode', res.trip.invite_code);",
									"  console.log('Invite code saved:', res.trip.invite_code);",
									"}",
									"if (res.owner && res.owner.id) {",
									"  pm.collectionVariables.set('memberId', res.owner.id);",
									"  console.log('Owner member ID saved:', res.owner.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"name\": \"日本中部北陸之旅\",\n\t\"start_date\": \"2026-03-20\",\n\t\"end_date\": \"2026-03-30\",\n\t\"owner_name\": \"劉冠呈\",\n\t\"owner_avatar_color\": \"#F59E0B\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "http://localhost:8080/trips",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["trips"]
						}
					}
				},
