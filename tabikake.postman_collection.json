{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
		"name": "Tabikake API",
		"description": "Auth uses httpOnly cookies — Postman's cookie jar handles this automatically. After the OAuth callback, all requests to localhost:8080 include the auth_token cookie.",
