		{
			"name": "Auth",
			"item": [
				{
					"name": "POST /auth/notion/callback",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var res = pm.response.json();",
									"if (res.access_token) {",
									"  pm.collectionVariables.set('token', res.access_token);",
									"  console.log('Token saved');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"code\": \"YOUR_NOTION_OAUTH_CODE\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "http://localhost:8080/auth/notion/callback",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["auth", "notion", "callback"]
						}
					}
				},
