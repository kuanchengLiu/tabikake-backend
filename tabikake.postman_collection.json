		},
		{
			"name": "Auth",
			"item": [
				{
					"name": "GET /auth/notion/url",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8080/auth/notion/url",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["auth", "notion", "url"]
						},
						"description": "Returns the Notion OAuth authorization URL. Open it in a browser to start the OAuth flow."
					}
				},
				{
					"name": "GET /auth/notion/callback",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Postman cookie jar automatically captures the auth_token cookie",
									"// from the Set-Cookie header in the redirect response.",
									"// No manual steps needed — subsequent requests will send the cookie."
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8080/auth/notion/callback?code={{oauthCode}}",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["auth", "notion", "callback"],
							"query": [
								{ "key": "code", "value": "{{oauthCode}}", "description": "Paste the code= value from Notion's redirect URL" }
							]
						},
						"description": "Exchanges the OAuth code for a session. Sets auth_token cookie. Paste the `code` param from Notion's redirect URL into the oauthCode variable."
					}
				},
				{
					"name": "GET /auth/me",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8080/auth/me",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["auth", "me"]
						}
					}
				},
				{
					"name": "POST /auth/logout",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "http://localhost:8080/auth/logout",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["auth", "logout"]
						}
					}
				}
			]
		},
		{
			"name": "Trips",
			"item": [
				{
					"name": "GET /trips",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8080/trips",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["trips"]
						}
					}
				},
				{
					"name": "POST /trips",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var res = pm.response.json();",
									"if (res.id) {",
									"  pm.collectionVariables.set('tripId', res.id);",
									"  console.log('Trip ID saved:', res.id);",
									"}",
									"if (res.invite_code) {",
									"  pm.collectionVariables.set('inviteCode', res.invite_code);",
									"  console.log('Invite code saved:', res.invite_code);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"name\": \"日本中部北陸之旅\",\n\t\"start_date\": \"2026-03-20\",\n\t\"end_date\": \"2026-03-30\",\n\t\"budget_jpy\": 150000,\n\t\"budget_suica\": 10000\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "http://localhost:8080/trips",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["trips"]
						}
					}
				},
				{
					"name": "GET /trips/:id",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8080/trips/{{tripId}}",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["trips", "{{tripId}}"]
						}
					}
				},
				{
					"name": "PATCH /trips/:id",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"name\": \"日本中部北陸之旅（更新）\",\n\t\"end_date\": \"2026-04-01\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "http://localhost:8080/trips/{{tripId}}",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["trips", "{{tripId}}"]
						},
						"description": "Owner only. All fields are optional."
					}
				},
				{
					"name": "DELETE /trips/:id",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "http://localhost:8080/trips/{{tripId}}",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["trips", "{{tripId}}"]
						},
						"description": "Owner only."
					}
				},
				{
					"name": "GET /trips/join-info (public)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8080/trips/join-info?code={{inviteCode}}",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["trips", "join-info"],
							"query": [
								{ "key": "code", "value": "{{inviteCode}}" }
							]
						}
					}
				},
				{
					"name": "POST /trips/join",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var res = pm.response.json();",
									"if (res.trip && res.trip.id) {",
									"  pm.collectionVariables.set('tripId', res.trip.id);",
									"  console.log('Trip ID saved:', res.trip.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"invite_code\": \"{{inviteCode}}\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "http://localhost:8080/trips/join",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["trips", "join"]
						},
						"description": "Joins the trip as the authenticated user. No extra fields needed — identity comes from the session cookie."
					}
				}
			]
		},
