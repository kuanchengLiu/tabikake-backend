							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "X-Member-ID", "value": "{{memberId}}", "description": "optional — populates is_member field" }
						],
						"url": {
							"raw": "http://localhost:8080/trips/{{tripId}}",
							"protocol": "http",
