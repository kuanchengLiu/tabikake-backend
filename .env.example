# Anthropic Claude API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Notion Integration Token (https://www.notion.so/my-integrations)
NOTION_INTEGRATION_TOKEN=ntn_...

# Notion OAuth App credentials (from your integration's OAuth settings)
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=

# Notion OAuth redirect URI — must point to this backend's callback endpoint.
# Register this exact value in your Notion integration's "Redirect URIs" list.
NOTION_OAUTH_REDIRECT_URI=http://localhost:8080/auth/notion/callback

# Notion root page — all trip pages will be created under this page.
# Create one page manually in Notion, then paste its ID here.
# Page URL: notion.so/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_ROOT_PAGE_ID=

# JWT signing secret
# Generate: openssl rand -base64 32
JWT_SECRET=

# AES-256-GCM key for encrypting stored Notion access tokens (must be exactly 32 bytes).
# Generate: openssl rand -base64 32
TOKEN_ENCRYPT_KEY=

# SQLite database file path (default: tabikake.db)
SQLITE_PATH=tabikake.db

# Server port (default: 8080)
PORT=8080

# Frontend origin for CORS and post-login redirect
FRONTEND_URL=http://localhost:3000
