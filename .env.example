# Anthropic Claude API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Notion Integration Token (https://www.notion.so/my-integrations)
NOTION_INTEGRATION_TOKEN=ntn_...

# Notion OAuth App credentials
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=

# Notion root page — all trip pages will be created under this page.
# Create one page manually in Notion, then paste its ID here.
# Page URL: notion.so/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_ROOT_PAGE_ID=

# Notion OAuth redirect URI (must match your integration settings)
NOTION_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# JWT signing secret (openssl rand -base64 32)
JWT_SECRET=

# SQLite database file path (default: tabikake.db)
SQLITE_PATH=tabikake.db

# Server port (default: 8080)
PORT=8080

# Frontend origin for CORS
FRONTEND_URL=http://localhost:3000
